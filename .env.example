# Environment Configuration
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite:///./inbox_tester.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/inbox_tester

# Gmail API Configuration
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/accounts/callback

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption
ENCRYPTION_KEY=your-encryption-key-32-chars-long!

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
FRONTEND_URL=http://localhost:5173

# Gmail API Rate Limiting
GMAIL_API_MAX_CONCURRENT=5
GMAIL_API_RATE_LIMIT=100
GMAIL_SCAN_TIMEOUT_SECONDS=60

# Email Sending
SEND_EMAIL_METHOD=gmail_api
# Alternative: smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_EMAIL=your-email@gmail.com

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Features
ENABLE_WEBHOOK_NOTIFICATIONS=false
ENABLE_SCHEDULED_TESTS=true
AUTO_RESCAN_ENABLED=true
AUTO_RESCAN_INTERVAL_SECONDS=10
AUTO_RESCAN_TIMEOUT_MINUTES=5

# Optional: Redis for caching
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS=false

# Timeouts
REQUEST_TIMEOUT_SECONDS=30
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
